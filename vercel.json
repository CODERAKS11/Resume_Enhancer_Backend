{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "python-ai-service/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/ai_service/(.*)",
      "dest": "python-ai-service/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
