{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "python-ai-service/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(parse-resume|analyze|ats-score|score-from-json|analyze-from-json|enhance-resume|parse-linkedin|get-resume-pdf/.*|parse-jd)",
      "dest": "python-ai-service/main.py"
    },
    {
      "src": "/ai_service/(.*)",
      "dest": "python-ai-service/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
